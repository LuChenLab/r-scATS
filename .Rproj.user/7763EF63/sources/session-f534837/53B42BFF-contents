IRangesList2GRangesList <- function(x, chr, strand) {
  stopifnot(is(x, "IRangesList"))
  stopifnot(is.character(chr)); stopifnot(length(chr) == 1)
  stopifnot(is.character(strand)); stopifnot(length(strand) == 1); stopifnot(is.element(strand, c("+", "-", "*")))
  oldname <- names(x)
  if(is.null(oldname)) names(x) <- seq_along(x)
  stopifnot(!any(duplicated(names(x))))
  y <- unlist(x)
  id <- names(y)
  names(y) <- NULL
  y <- GRangesList(split(GRanges(chr, y, strand), id))
  y <- y[names(x)]
  if(is.null(oldname)) names(y) <- NULL
  return(y)
}


